# Rendir.ai — variables de entorno (PLANTILLA)
# Copia este archivo a .env y completa los valores. NUNCA subas el .env real.

# Clave de la API de Claude (Anthropic)
ANTHROPIC_API_KEY=tu_clave_aqui

# Modelo de Claude a usar
ANTHROPIC_MODEL=claude-opus-4-8

# URL del backend (la usa el frontend Streamlit)
BACKEND_URL=http://localhost:8000

# Base de datos (SQLite local por defecto; en prod usar Postgres de Render)
DATABASE_URL=sqlite:///./rendir.db
